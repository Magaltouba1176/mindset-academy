# ─────────────────────────────────────────────
#  Mindset Academy — Environment Variables
#  Copy this file to .env and fill in your keys
#  NEVER commit .env to git
# ─────────────────────────────────────────────

# PayDunya API Keys (from your PayDunya dashboard)
PAYDUNYA_MASTER_KEY=your-master-key-here
PAYDUNYA_PRIVATE_KEY=your-private-key-here
PAYDUNYA_TOKEN=your-token-here

# PayDunya mode: "test" or "live"
PAYDUNYA_MODE=test

# Your domain (used for return URLs)
# Example: https://mindsetacademy.papasdioufs.com
APP_URL=http://localhost:3000

# Server port
PORT=3000
